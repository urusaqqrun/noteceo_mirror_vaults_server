{
  "mcpServers": {
    "serper-search": {
      "command": "node",
      "args": ["/app/config/mcp_serper_server.mjs"],
      "timeout": 30
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/pre-write-validate.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/pre-bash-safety.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/pre-read-edit-validate.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "LS|Glob|Grep|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/pre-ls-glob-grep-validate.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"decision\":\"block\",\"reason\":\"禁止使用內建 WebSearch/WebFetch，請改用 MCP web_search 工具（serper-search server）\"}'",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/post-write-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/app/config/hooks/stop-final-validate.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
