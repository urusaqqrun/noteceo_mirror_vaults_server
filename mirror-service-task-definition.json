{
    "family": "mirror-service",
    "networkMode": "awsvpc",
    "executionRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::<AWS_ACCOUNT_ID>:role/cubelv-task-role",
    "cpu": "512",
    "memory": "1024",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "volumes": [
        {
            "name": "vault-efs",
            "efsVolumeConfiguration": {
                "fileSystemId": "<EFS_FILE_SYSTEM_ID>",
                "transitEncryption": "ENABLED",
                "authorizationConfig": {
                    "accessPointId": "<EFS_ACCESS_POINT_ID>",
                    "iam": "ENABLED"
                }
            }
        }
    ],
    "containerDefinitions": [
        {
            "name": "mirror-service",
            "image": "<AWS_ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/mirror-service:latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 8080,
                    "hostPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "mountPoints": [
                {
                    "sourceVolume": "vault-efs",
                    "containerPath": "/vaults",
                    "readOnly": false
                }
            ],
            "environment": [
                {
                    "name": "AWS_REGION",
                    "value": "ap-northeast-1"
                },
                {
                    "name": "GOMAXPROCS",
                    "value": "1"
                },
                {
                    "name": "VAULT_ROOT",
                    "value": "/vaults"
                },
                {
                    "name": "SYNC_LOOP_INTERVAL_SEC",
                    "value": "30"
                },
                {
                    "name": "SYNC_CURSOR_LEASE_SEC",
                    "value": "120"
                },
                {
                    "name": "SYNC_OWNER_SCAN_LIMIT",
                    "value": "128"
                },
                {
                    "name": "SYNC_CHANGE_BATCH_SIZE",
                    "value": "100"
                }
            ],
            "secrets": [
                {
                    "name": "MODE",
                    "valueFrom": "arn:aws:ssm:ap-northeast-1:<AWS_ACCOUNT_ID>:parameter/cubelv/MODE"
                },
                {
                    "name": "PORT",
                    "valueFrom": "arn:aws:ssm:ap-northeast-1:<AWS_ACCOUNT_ID>:parameter/cubelv/MIRROR_PORT"
                },
                {
                    "name": "POSTGRES_URI",
                    "valueFrom": "arn:aws:ssm:ap-northeast-1:<AWS_ACCOUNT_ID>:parameter/cubelv/POSTGRES_URI"
                },
                {
                    "name": "REDIS_URI",
                    "valueFrom": "arn:aws:ssm:ap-northeast-1:<AWS_ACCOUNT_ID>:parameter/cubelv/REDIS_URI"
                },
                {
                    "name": "ANTHROPIC_API_KEY",
                    "valueFrom": "arn:aws:ssm:ap-northeast-1:<AWS_ACCOUNT_ID>:parameter/cubelv/ANTHROPIC_API_KEY"
                },
                {
                    "name": "SERPER_API_KEY",
                    "valueFrom": "arn:aws:ssm:ap-northeast-1:<AWS_ACCOUNT_ID>:parameter/cubelv/SERPER_API_KEY"
                },
                {
                    "name": "JWT_SECRET",
                    "valueFrom": "arn:aws:ssm:ap-northeast-1:<AWS_ACCOUNT_ID>:parameter/membercenter/JWT_SECRET"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-region": "ap-northeast-1",
                    "awslogs-group": "/ecs/mirror-service",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "curl -f http://localhost:8080/health || exit 1"
                ],
                "interval": 30,
                "timeout": 5,
                "retries": 3,
                "startPeriod": 60
            }
        }
    ]
}
